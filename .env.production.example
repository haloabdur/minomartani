#--------------------------------------------------------------------
# PRODUCTION ENVIRONMENT TEMPLATE
#
# Copy this to `.env` on the production server and fill in the real
# values. Never commit the filled-in `.env` - it's gitignored.
#
# See DEPLOYMENT.md for the full deployment checklist.
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'https://rt29minomartani.com/'
# The 'forcehttps' filter is enabled by default (app/Config/Filters.php
# $required['before']) - the site MUST be served over TLS in production
# or every request will redirect-loop. Get a real TLS cert first.

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = REPLACE_WITH_PROD_DB_NAME
database.default.username = REPLACE_WITH_PROD_DB_USER
database.default.password = REPLACE_WITH_PROD_DB_PASSWORD
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# Generate on the production server itself with `php spark key:generate`
# - do NOT reuse the development key. Keep this value secret; Shield's
# remember-me tokens and encrypted session data depend on it.
# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# Default threshold (4) logs errors/warnings/notices - fine for
# production. Raise to 1 (errors only) if disk space on the host is
# tight; the app doesn't currently need debug-level (9) logging live.
# logger.threshold = 4

#--------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (login form)
#--------------------------------------------------------------------

# Site Key and Secret Key come from the Cloudflare dashboard - Turnstile
# widget settings. They are two DIFFERENT values (site key is public,
# embedded in the login page; secret key is server-side only, used by
# app/Filters/TurnstileFilter.php to call Cloudflare's siteverify API).
# If secretKey is blank or wrong, every login attempt is blocked.
# turnstile.enabled defaults to true when CI_ENVIRONMENT = production
# (see app/Config/Turnstile.php) - no need to set it here unless you
# want to force it off.
turnstile.siteKey = REPLACE_WITH_TURNSTILE_SITE_KEY
turnstile.secretKey = REPLACE_WITH_TURNSTILE_SECRET_KEY
